<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a">

    <!-- Wallpaper background -->
    <ImageView
        android:id="@+id/wallpaper_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- White overlay 25% -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40FFFFFF" />

    <!-- Toast container -->
    <TextView
        android:id="@+id/toast_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="16dp"
        android:padding="12dp"
        android:gravity="center"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#3b82f6"
        android:visibility="gone" />

    <!-- Main layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header (glass) -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="#BFFFFFFF"
            android:elevation="4dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/logo"
                android:scaleType="centerCrop"
                android:background="@drawable/circle_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:text="Spidi Clicker"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1a1a1a" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/medal_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/medal"
                android:visibility="gone"
                android:layout_marginRight="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="#1E3b82f6"
                android:backgroundTint="#1E3b82f6">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/coin"
                    android:scaleType="centerInside" />

                <TextView
                    android:id="@+id/coins_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1a1a1a"
                    android:layout_marginLeft="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Content -->
        <FrameLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom Nav (glass) -->
        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:background="#BFFFFFFF"
            android:elevation="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:id="@+id/tab_game"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/button_secondary_bg">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/game"
                    android:scaleType="centerInside" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Игра"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#1a1a1a"
                    android:layout_marginTop="2dp" />

                <View
                    android:id="@+id/tab_game_indicator"
                    android:layout_width="24dp"
                    android:layout_height="3dp"
                    android:background="#3b82f6"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_upgrades"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/upgrades"
                    android:scaleType="centerInside" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Улучш."
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#9ca3af"
                    android:layout_marginTop="2dp" />

                <View
                    android:id="@+id/tab_upgrades_indicator"
                    android:layout_width="24dp"
                    android:layout_height="3dp"
                    android:background="#3b82f6"
                    android:visibility="gone"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_gifts"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/gifts"
                    android:scaleType="centerInside" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Подарки"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#9ca3af"
                    android:layout_marginTop="2dp" />

                <View
                    android:id="@+id/tab_gifts_indicator"
                    android:layout_width="24dp"
                    android:layout_height="3dp"
                    android:background="#3b82f6"
                    android:visibility="gone"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/settings"
                    android:scaleType="centerInside" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Настр."
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#9ca3af"
                    android:layout_marginTop="2dp" />

                <View
                    android:id="@+id/tab_settings_indicator"
                    android:layout_width="24dp"
                    android:layout_height="3dp"
                    android:background="#3b82f6"
                    android:visibility="gone"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
        </LinearLayout>

        <!-- Content -->
        <FrameLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

