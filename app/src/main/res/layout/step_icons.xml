<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Пак иконок"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1a1a1a"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Выбери стиль иконок для игры"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp" />

    <!-- NEW PACK -->
    <LinearLayout
        android:id="@+id/option_new_pack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/device_select_bg"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/click_default"
                android:scaleType="centerInside"
                android:layout_marginEnd="4dp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/coin"
                android:scaleType="centerInside" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW PACK"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1a1a1a" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Современные иконки v3.1"
                android:textSize="11sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <View
            android:id="@+id/indicator_new_pack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="#3b82f6"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/icon_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#ef4444"
        android:background="#fef2f2"
        android:padding="12dp"
        android:visibility="gone" />
</LinearLayout>
