<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallpaper_1">



    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#E6FFFFFF"
                android:padding="20dp"
                android:layout_margin="16dp"
                android:elevation="4dp">

                <!-- Logo and Title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/logo"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_bg" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spidi Clicker v3.1"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1a1a1a" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Персонализация"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Progress Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <View
                        android:id="@+id/progress_step_1"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="#FF9800" />

                    <View
                        android:id="@+id/progress_step_2"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />

                    <View
                        android:id="@+id/progress_step_3"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />

                    <View
                        android:id="@+id/progress_step_4"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />

                    <View
                        android:id="@+id/progress_step_5"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />
                </LinearLayout>

                <!-- Step Labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/label_step_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Устройство"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#1a1a1a" />

                    <TextView
                        android:id="@+id/label_step_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Фон"
                        android:textSize="10sp"
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/label_step_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Иконки"
                        android:textSize="10sp"
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/label_step_4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Музыка"
                        android:textSize="10sp"
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/label_step_5"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Старт"
                        android:textSize="10sp"
                        android:textColor="#666666" />
                </LinearLayout>

                <!-- Content Container (dynamic steps) -->
                <FrameLayout
                    android:id="@+id/step_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp" />

                <!-- Navigation Buttons -->
                <LinearLayout
                    android:id="@+id/navigation_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:visibility="gone">

                    <ImageButton
                        android:id="@+id/btn_back"
                        android:layout_width="wrap_content"
                        android:layout_height="45dp"
                        android:src="@drawable/button_Click.jpg"
                        android:background="@android:color/transparent"
                        android:paddingHorizontal="20dp"
                        android:enabled="false" />

                    <TextView
                        android:id="@+id/step_counter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Шаг 1 из 5"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginHorizontal="16dp" />

                    <ImageButton
                        android:id="@+id/btn_next"
                        android:layout_width="wrap_content"
                        android:layout_height="45dp"
                        android:src="@drawable/button_Click.jpg"
                        android:background="@android:color/transparent"
                        android:paddingHorizontal="24dp" />
                </LinearLayout>

                <!-- Final Start Button (step 5) -->
                <ImageButton
                    android:id="@+id/btn_start"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:src="@drawable/button_Click.jpg"
                    android:background="@android:color/transparent"
                    android:layout_marginTop="20dp"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
