<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallpaper_1">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40FFFFFF" />

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#E6FFFFFF"
        android:elevation="4dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/logo"
            android:scaleType="centerCrop" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Spidi Clicker"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1a1a1a"
            android:layout_marginStart="8dp" />

        <ImageView
            android:id="@+id/medal_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/medal"
            android:visibility="gone"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#e8f4fd"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginStart="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/coin"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/coins_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1a1a1a"
                android:layout_marginStart="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content -->
    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_nav"
        android:layout_below="@id/header" />

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#E6FFFFFF"
        android:elevation="4dp"
        android:paddingVertical="8dp">

        <!-- Game Tab -->
        <LinearLayout
            android:id="@+id/tab_game"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/game"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Игра"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#3b82f6"
                android:layout_marginTop="2dp" />

            <View
                android:id="@+id/tab_game_indicator"
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="#3b82f6"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Upgrades Tab -->
        <LinearLayout
            android:id="@+id/tab_upgrades"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/upgrades"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Улучш."
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#999999"
                android:layout_marginTop="2dp" />

            <View
                android:id="@+id/tab_upgrades_indicator"
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="#3b82f6"
                android:visibility="gone"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Gifts Tab -->
        <LinearLayout
            android:id="@+id/tab_gifts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/gifts"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Подарки"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#999999"
                android:layout_marginTop="2dp" />

            <View
                android:id="@+id/tab_gifts_indicator"
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="#3b82f6"
                android:visibility="gone"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Settings Tab -->
        <LinearLayout
            android:id="@+id/tab_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/settings"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Настр."
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#999999"
                android:layout_marginTop="2dp" />

            <View
                android:id="@+id/tab_settings_indicator"
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="#3b82f6"
                android:visibility="gone"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Toast Container -->
    <TextView
        android:id="@+id/toast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:padding="12dp"
        android:background="#22c55e"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:elevation="8dp" />
</FrameLayout>
