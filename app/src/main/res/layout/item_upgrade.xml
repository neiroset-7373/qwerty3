<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:background="#BFFFFFFF"
    android:elevation="4dp">

    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:background="#1E3b82f6"
        android:backgroundTint="#1E3b82f6">

        <TextView
            android:id="@+id/upgrade_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕2"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#3b82f6" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginLeft="12dp">

        <TextView
            android:id="@+id/upgrade_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Множитель x2"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1a1a1a" />

        <TextView
            android:id="@+id/upgrade_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Удваивает силу клика"
            android:textSize="12sp"
            android:textColor="#6b7280"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/upgrade_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Осталось: 23ч"
            android:textSize="12sp"
            android:textColor="#3b82f6"
            android:visibility="gone"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/upgrade_cost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="250 💰"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1a1a1a" />

        <Button
            android:id="@+id/buy_btn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Купить"
            android:textSize="11sp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginTop="4dp"
            android:backgroundTint="#3b82f6"
            android:textColor="#ffffff" />
    </LinearLayout>
</LinearLayout>

        <TextView
            android:id="@+id/upgrad_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Описание"
            android:textSize="11sp"
            android:textColor="#666666"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/buy_button"
        android:layout_width="70dp"
        android:layout_height="42dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/button_primary_bg"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/coin"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/upgrad_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginLeft="2dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Купить"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:alpha="0.8" />
    </LinearLayout>
</LinearLayout>
