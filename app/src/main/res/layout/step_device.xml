<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Выбери устройство"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1a1a1a"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Интерфейс адаптируется под твоё устройство"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Phone Option -->
        <LinearLayout
            android:id="@+id/option_phone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:background="@drawable/device_select_bg"
            android:layout_margin="4dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/phone"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Телефон"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#3b82f6"
                android:layout_marginTop="8dp" />

            <View
                android:id="@+id/indicator_phone"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#3b82f6"
                android:visibility="gone"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Tablet Option -->
        <LinearLayout
            android:id="@+id/option_tablet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:background="@drawable/device_select_bg"
            android:layout_margin="4dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/tablet"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Планшет"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#666666"
                android:layout_marginTop="8dp" />

            <View
                android:id="@+id/indicator_tablet"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#3b82f6"
                android:visibility="gone"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
