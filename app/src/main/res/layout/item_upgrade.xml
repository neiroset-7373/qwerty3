<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:background="#E6FFFFFF"
    android:layout_marginBottom="8dp"
    android:elevation="2dp">

    <View
        android:id="@+id/upgrad_icon_bg"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="#e8f4fd"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/upgrad_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Название"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1a1a1a" />

            <TextView
                android:id="@+id/upgrad_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#22c55e"
                android:background="#dcfce7"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginStart="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/upgrad_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Описание"
            android:textSize="11sp"
            android:textColor="#666666"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/buy_button"
        android:layout_width="70dp"
        android:layout_height="42dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/button_primary_bg"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/coin"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/upgrad_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Купить"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:alpha="0.8" />
    </LinearLayout>
</LinearLayout>
