<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:max="100"
                android:progress="20"
                android:layout_marginBottom="24dp" />

            <!-- Step Counter -->
            <TextView
                android:id="@+id/step_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Шаг 1 из 5"
                android:textSize="14sp"
                android:textColor="#9ca3af"
                android:layout_marginBottom="8dp" />

            <!-- Step Title -->
            <TextView
                android:id="@+id/step_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выберите устройство"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:layout_marginBottom="8dp" />

            <!-- Step Description -->
            <TextView
                android:id="@+id/step_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="С чего вы будете играть?"
                android:textSize="16sp"
                android:textColor="#9ca3af"
                android:layout_marginBottom="32dp" />

            <!-- Step Content -->
            <FrameLayout
                android:id="@+id/step_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp" />

            <!-- Navigation Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/back_btn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Назад"
                    android:backgroundTint="#4b5563"
                    android:textColor="#ffffff"
                    android:visibility="gone"
                    android:layout_marginRight="8dp" />

                <Button
                    android:id="@+id/next_btn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Далее"
                    android:backgroundTint="#3b82f6"
                    android:textColor="#ffffff"
                    android:layout_marginLeft="8dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
                </LinearLayout>

                <!-- Progress Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <View
                        android:id="@+id/progress_step_1"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="#3b82f6" />

                    <View
                        android:id="@+id/progress_step_2"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />

                    <View
                        android:id="@+id/progress_step_3"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />

                    <View
                        android:id="@+id/progress_step_4"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />

                    <View
                        android:id="@+id/progress_step_5"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />
                </LinearLayout>

                <!-- Step Counter -->
                <TextView
                    android:id="@+id/step_counter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Шаг 1 из 5"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginTop="4dp" />

                <!-- Step Labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/label_step_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Устройство"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#1a1a1a" />

                    <TextView
                        android:id="@+id/label_step_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Фон"
                        android:textSize="10sp"
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/label_step_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Иконки"
                        android:textSize="10sp"
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/label_step_4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Музыка"
                        android:textSize="10sp"
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/label_step_5"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Старт"
                        android:textSize="10sp"
                        android:textColor="#666666" />
                </LinearLayout>

                <!-- Content Container (dynamic steps) -->
                <FrameLayout
                    android:id="@+id/step_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp" />

                <!-- Navigation Buttons -->
                <LinearLayout
                    android:id="@+id/navigation_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/btn_back"
                        android:layout_width="wrap_content"
                        android:layout_height="45dp"
                        android:text="Назад"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1a1a1a"
                        android:background="@drawable/button_secondary_bg"
                        android:paddingLeft="20dp"
                        android:paddingRight="20dp"
                        android:enabled="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="или"
                        android:textSize="12sp"
                        android:textColor="#1a1a1a"
                        android:layout_marginLeft="16dp"
                        android:layout_marginRight="16dp" />

                    <Button
                        android:id="@+id/btn_next"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Далее →"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/button_primary_bg"
                        android:paddingLeft="24dp"
                        android:paddingRight="24dp" />
                </LinearLayout>

                <!-- Final Start Button (step 5) -->
                <Button
                    android:id="@+id/btn_start"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Начать игру!"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_primary_bg"
                    android:layout_marginTop="20dp"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
